# Copy this file to server/.env and paste your key in.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional — the API port (the client proxies /api and /uploads here)
PORT=3001

# The artist name(s) to pull off a roster/lineup. Comma-separated; all treated
# as the same person. Sets by anyone else on the bill are ignored.
ARTIST_ALIASES=Dave,Davoted,Dave Davoted,Nvara
